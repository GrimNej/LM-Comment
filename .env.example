# Relay only. Never prefix the Groq key with EXPO_PUBLIC_.
GROQ_API_KEY=
DEMO_TOKEN=replace-with-a-short-lived-demo-token
PORT=3000
GROQ_MODEL=openai/gpt-oss-120b
MAX_REQUESTS_PER_MINUTE=3
MAX_DAILY_REQUESTS=100
MAX_SOURCE_CHARACTERS=8000
MAX_COMPLETION_TOKENS=700
GENERATION_ENABLED=true

# Mobile build-time demo defaults. The token is a temporary demo gate, not a
# provider credential. Leave blank for public builds.
EXPO_PUBLIC_RELAY_BASE_URL=
EXPO_PUBLIC_DEMO_TOKEN=
